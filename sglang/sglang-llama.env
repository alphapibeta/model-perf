# =========================
# MODEL
# =========================
MODEL_PATH=meta-llama/Meta-Llama-3.1-8B-Instruct
SERVED_MODEL_NAME=meta-llama/Meta-Llama-3.1-8B-Instruct

# =========================
# GPU
# =========================
CUDA_DEVICES=1
TP_SIZE=1
# =========================
# SERVER
# =========================
HOST=0.0.0.0
PORT=30000
CONTAINER_NAME=sglang-llama-server
IMAGE_NAME=lmsysorg/sglang:latest

# =========================
# MEMORY / PERFORMANCE
# =========================
MEM_FRACTION_STATIC=0.85
CHUNKED_PREFILL_SIZE=2048
MAX_PREFILL_TOKENS=16384

# =========================
# CACHE
# =========================
HF_HOME=/root/.cache/huggingface
HF_CACHE_HOST_PATH=/root/.cache/huggingface

# IMPORTANT: leave blank and export in shell

# =========================
# NVIDIA / SYSTEM
# =========================
SHM_SIZE=16g
NVIDIA_DRIVER_CAPABILITIES=compute,utility,video
NCCL_DEBUG=INFO
NCCL_DEBUG_SUBSYS=INIT,ENV

# =========================
# FLAGS
# =========================
DISABLE_CUDA_GRAPH=0
LOG_LEVEL=info










# =========================
# BENCHMARK CONFIG
# =========================

# Endpoint config
TOKENIZER=meta-llama/Meta-Llama-3.1-8B-Instruct
ENDPOINT_TYPE=chat
STREAMING=true

STREAMING_LONGCTX=false

# Optional per-suite streaming overrides (default to STREAMING if unset)
# STREAMING_BASELINE=true
# STREAMING_CONCURRENCY=true
STREAMING_LONGCTX=false
# STREAMING_STRESS=true

# Request counts
REQUEST_COUNT_BASELINE=10
REQUEST_COUNT_CONCURRENCY=128
REQUEST_COUNT_LONGCTX=16
REQUEST_COUNT_STRESS=256

# Concurrency levels
CONCURRENCY_LEVELS="1 2 4 6 16 32 64 128 256 512 1024"
LONGCTX_CONCURRENCY_LEVELS="1 2 4 6 16 32 64 128 256 512 1024"
STRESS_CONCURRENCY_LEVELS="1 2 4 6 16 32 64 128 256 512 1024"
# Token sizes
INPUT_TOKENS_BASELINE=256
OUTPUT_TOKENS_BASELINE=128

INPUT_TOKENS_CONCURRENCY=512
OUTPUT_TOKENS_CONCURRENCY=160

INPUT_TOKENS_LONGCTX=4000
OUTPUT_TOKENS_LONGCTX=2000

INPUT_TOKENS_STRESS=2000
OUTPUT_TOKENS_STRESS=512

# =========================
# OPTIONAL
# =========================
SHM_SIZE=16g
NCCL_DEBUG=INFO
NCCL_DEBUG_SUBSYS=INIT,ENV


